# OpenAI (서버 전용 — 클라이언트에 절대 노출 금지)
OPENAI_API_KEY=sk-...

# 모델
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_VISION_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-small

# 벡터스토어 (MVP는 in-memory; 운영 시 pgvector 등)
VECTOR_STORE=memory
# DATABASE_URL=postgres://...

# AI Hub 원천 데이터 경로 (gitignore된 data/aihub/)
AIHUB_DATA_DIR=./data/aihub
