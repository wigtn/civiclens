# ============================================================
# CivicLens server (B stream) — 로컬 환경변수 예시
# 복사: cp .env.example .env  (.env 는 커밋 금지)
# ============================================================

# OpenAI 비밀키 — 서버 전용. 절대 NEXT_PUBLIC_* 로 노출 금지(§4.5).
OPENAI_API_KEY=

# Realtime 모델/보이스
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=alloy

# 실제 OpenAI 호출 토글. 로컬 기본값은 mock(가짜 ek_ 토큰, OpenAI 미호출).
# 실제 ephemeral 토큰을 발급하려면 1 로 설정 + OPENAI_API_KEY 필요.
CIVICLENS_USE_OPENAI=

# 세션 토큰 서명 비밀(선택). 미설정 시 프로세스 1회 랜덤(재시작 시 토큰 무효).
CIVICLENS_TOKEN_SECRET=

# 일일 비용 캡(USD). 누적 추정 비용이 이 값을 넘으면 503 BUDGET_EXCEEDED.
CIVICLENS_DAILY_BUDGET_USD=5

# CORS 허용 Origin(쉼표 구분). 로컬 dev 기본 포함. 와일드카드 금지.
CIVICLENS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000
