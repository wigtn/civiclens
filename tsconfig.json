{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@contract/*": ["shared/contract/*"]
    }
  },
  "include": ["server/**/*.ts", "scripts/**/*.ts", "shared/**/*.ts"],
  "exclude": ["node_modules", "mobile"]
}
